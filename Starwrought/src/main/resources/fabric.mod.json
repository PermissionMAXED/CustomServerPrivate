	"authors": ["Atomi", "Cursor Cloud Agents"],
	"contact": {
		"homepage": "https://github.com/PermissionMAXED/CustomServerPrivate",
		"sources": "https://github.com/PermissionMAXED/CustomServerPrivate"
	},
	"license": "MIT",
	"icon": "assets/starwrought/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": ["de.atomi.starwrought.Starwrought"],
		"client": ["de.atomi.starwrought.client.StarwroughtClient"]
	},
	"mixins": [
