ASPNETCORE_URLS=http://0.0.0.0:5055

# Public URL players enter or the client mod points to.
CustomServer__PublicBaseUrl=http://YOUR_PUBLIC_IP:5055

# Host/IP sent to clients in GAME_STARTED for the actual Unity match transport.
CustomServer__PublicGameHost=YOUR_PUBLIC_IP

# Keep false until the old Unity build is proven to start as a dedicated match server on Linux/Wine.
CustomServer__LaunchGameServers=false
CustomServer__RequireGameServerBootstrap=true

# Linux dedicated server build shape.
# CustomServer__LaunchGameServers=true
# CustomServer__GameExecutablePath=/opt/bapbap/game/bapbap.x86_64
# CustomServer__GameWorkingDirectory=/opt/bapbap/game
#
# Experimental Wine shape for the provided Windows build. This did not yet pass bootstrap testing.
# CustomServer__LaunchGameServers=true
# CustomServer__GameLauncherPath=wine
# CustomServer__GameLauncherArguments="{gameExecutable}" {gameArguments}
# CustomServer__GameExecutablePath=/opt/bapbap/build/bapbap.exe
# CustomServer__GameWorkingDirectory=/opt/bapbap/build
# CustomServer__HeadlessArguments=-batchmode -nographics -logFile "{logFile}" -httpport={httpPort} -wsport={wsPort} -kcpport={kcpPort} -tcpport={tcpPort}

CustomServer__BaseHttpPort=7850
CustomServer__BaseWsPort=7777
CustomServer__BaseKcpPort=7778
CustomServer__BaseTcpPort=7779
CustomServer__PortSearchRange=200
CustomServer__BootstrapConnectPath=/setup-game
CustomServer__BootstrapAddTeamsPath=/add-teams
CustomServer__BootstrapQueueMatchedPath=/queue-matched
