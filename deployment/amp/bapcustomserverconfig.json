[
  {
    "DisplayName": "Match Start Policy",
    "Description": "Controls which match-start paths are allowed. Both = matchmaking queue AND custom matches. MatchmakingOnly = only the queue (custom match lobbies are blocked). CustomOnly = only host-controlled custom matches (queue is blocked). The mod reads this on startup and adjusts the in-game UI / blocks rejected requests.",
    "FieldName": "MatchmakingPolicy",
    "InputType": "enum",
    "Category": "BAPBAP Custom Server",
    "Subcategory": "Match Policy",
    "ParamFieldName": "CustomServer.MatchmakingPolicy",
    "DefaultValue": "Both",
    "EnumValues": {
      "Both (matchmaking + custom)": "Both",
      "Matchmaking only": "MatchmakingOnly",
      "Custom matches only": "CustomOnly"
    }
  },
  {
    "DisplayName": "Max Concurrent Matches",
    "Description": "Cap on simultaneously running matches. 0 = unlimited (default). When the cap is hit, START_CUSTOM_GAME returns ERR_SERVER_FULL and the matchmaking timer waits until a slot frees.",
    "FieldName": "MaxConcurrentMatches",
    "InputType": "number",
    "Category": "BAPBAP Custom Server",
    "Subcategory": "Match Policy",
    "ParamFieldName": "CustomServer.MaxConcurrentMatches",
    "DefaultValue": "0"
  },
